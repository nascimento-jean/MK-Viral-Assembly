/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    viral-assembly Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'viral-assembly'
    author          = 'LACEN-AL / UFAL Genomic Surveillance'
    description      = 'Virus-agnostic reference-based consensus assembly from Illumina short reads'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '1.0.0'
}

/*
    Default parameters
*/
params {
    // Input / output
    input           = null
    outdir          = 'results'
    reference       = null          // global reference FASTA (per-sample overrides in samplesheet)
    virus           = null          // global virus label for folder mode (samplesheet has a per-row 'virus' column).
                                    // Names the outdir/<virus>/ subfolder + dashboard prefix; defaults to 'unspecified_virus'.
    gff             = null          // global GFF3 for iVar AA annotation (per-sample override in samplesheet)
    primer_bed      = null          // amplicon primer BED (optional)

    // Reference / consensus thresholds
    min_cov         = 20            // min coverage/depth to call a base (else N)
    min_depth       = null          // DEPRECATED alias of --min_cov (kept for back-compat)
    min_freq        = 0.75          // min alt frequency for consensus call
    min_qual        = 20            // min base quality (ivar)
    min_map_qual    = 20            // min mapping quality

    // FASTQ auto-discovery (folder input mode)
    fastq_pattern   = null          // optional custom glob if your files use an unusual naming

    // Aligner
    aligner         = 'bwa'         // 'bwa' or 'minimap2'

    // Optional taxonomic screen (Kraken2) + host-read depletion
    kraken2_db      = null          // path to a Kraken2 database => enables the taxonomic screen, Krona and taxonomy tab
    deplete_host    = false         // remove host reads (taxid --host_taxid) before alignment (requires kraken2_db)
    host_taxid      = 9606          // NCBI taxid depleted when --deplete_host is set (9606 = Homo sapiens)

    // Intra-sample heterozygosity screen (contamination / co-infection signal)
    mixed_min_freq  = 0.20          // minor-allele freq lower bound for a "mixed" site
    mixed_max_freq  = 0.80          // minor-allele freq upper bound for a "mixed" site

    // Lineage / genotype typing (Nextclade) — downstream of the consensus
    nextclade             = false   // enable Nextclade typing
    nextclade_dataset     = null    // catalog name (e.g. nextstrain/sars-cov-2/wuhan-hu-1/orfs)
                                    // OR a short virus alias (sars-cov-2, dengue, chikv, rsv-a,
                                    // rsv-b, zika, oropouche). 'oropouche' auto-runs the L/M/S tefe trio.
    nextclade_tag         = null    // pin a dataset version for reproducible reports; null => latest (recorded in report)
    nextclade_datasets_dir = "${projectDir}/assets/nextclade_datasets"  // persistent dataset cache

    // Species confirmation (BLAST vs local RefSeq viral) — downstream of the consensus
    blast_id              = false   // enable blastn species confirmation of the assembled consensus
    blast_db_dir          = "${projectDir}/assets/blast_refseq_viral"   // persistent RefSeq viral DB
    blast_db_max_age_days = 7       // rebuild the local RefSeq DB if older than this (checked each run)
    blast_db_min_rate_bytes = 1000  // download throughput floor (B/s); below this for _stall_seconds -> abort+retry
    blast_db_stall_seconds  = 60    // seconds under the rate floor before a stalled download is retried
    blast_db_max_tries      = 20    // max download retries before failing the process (NCBI can be slow)

    // Skips
    skip_fastqc     = false
    skip_multiqc    = false
    skip_mixed_sites = false        // set true to skip the intra-sample heterozygosity screen
    skip_dashboard  = false         // set true to skip the HTML surveillance dashboard

    // Dashboard (HTML surveillance report) thresholds
    run_name        = null          // label shown in the dashboard header (defaults to Nextflow run name)
    skip_combine    = false         // skip building the run-level combined multi-FASTA(s)
    combine_min_status = 'WARN'     // lowest QC status kept in the combined FASTA(s): PASS|WARN|FAIL (WARN => drop FAIL)
    dash_pass       = 0.90          // min consensus completeness for a PASS badge
    dash_warn       = 0.70          // min consensus completeness for a WARN badge (below -> FAIL)

    // Misc
    help            = false
    publish_dir_mode = 'copy'

    // resource ceilings (per-process labels can request up to these)
    max_cpus        = 16
    max_memory      = '60.GB'
    max_time        = '24.h'
}

/*
    Load process resource labels and per-module publishing rules
*/
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

/*
    Execution profiles
*/
profiles {

    debug {
        process.beforeScript = 'echo $HOSTNAME'
        cleanup = false
    }

    conda {
        conda.enabled          = true
        conda.channels         = ['conda-forge', 'bioconda']
        docker.enabled         = false
        singularity.enabled    = false
    }

    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        conda.channels         = ['conda-forge', 'bioconda']
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        conda.enabled          = false
        singularity.enabled    = false
        // each process declares an explicit `container` (biocontainers);
        // images are pulled directly from quay.io — no Wave/build step.
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // pull the same docker/OCI images and convert to SIF automatically
        singularity.ociAutoPull = true
        docker.enabled         = false
        conda.enabled          = false
    }

    test { includeConfig 'conf/test.config' }

    // Run with tools already on PATH (no container/conda engine). Useful for
    // CI or a preconfigured conda env. Combine with 'test': -profile test,standalone
    standalone {
        docker.enabled      = false
        singularity.enabled = false
        conda.enabled       = false
        wave.enabled        = false
    }
}

/*
    Reporting / provenance (reproducibility). timestamp keeps successive
    runs from overwriting each other's reports.
*/
timeline { enabled = true; file = "${params.outdir}/pipeline_info/execution_timeline_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/execution_report_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/execution_trace_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.txt" }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/pipeline_dag_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }

workflow.onComplete = {
    println ( workflow.success
        ? "\n[viral-assembly] Completed OK. Results in: ${params.outdir}\n"
        : "\n[viral-assembly] Finished with errors. Check .nextflow.log\n" )
}
