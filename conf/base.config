/*
    Base resource requests. Process labels are assigned in each module.
    The `resourceLimits` directive (Nextflow >=24.04) caps every request at
    params.max_* so the pipeline degrades gracefully on a laptop or scales
    up on a cluster. Requests grow with task.attempt for automatic retries.
*/

process {

    resourceLimits = [
        cpus:   params.max_cpus,
        memory: params.max_memory as nextflow.util.MemoryUnit,
        time:   params.max_time   as nextflow.util.Duration
    ]

    cpus   = { 1    * task.attempt }
    memory = { 4.GB * task.attempt }
    time   = { 2.h  * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    withLabel:process_single {
        cpus   = { 1 }
        memory = { 2.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 4.GB  * task.attempt }
        time   = { 2.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 12    * task.attempt }
        memory = { 24.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
