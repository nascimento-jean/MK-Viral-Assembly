/*
    Minimal test profile. Runs on a small simulated dataset generated by
    bin/make_testdata.sh (or the assets shipped with the repo). Uses tiny
    resources so it completes on a laptop / CI runner.

    Usage:
      nextflow run main.nf -profile test,docker --outdir results_test
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Small simulated SARS-CoV-2-style dataset to exercise the full pipeline'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '1.h'

    // these paths are created by `bash bin/make_testdata.sh testdata/`
    input      = "${projectDir}/testdata/samplesheet.csv"
    reference  = "${projectDir}/testdata/reference.fasta"

    min_cov    = 5
    min_freq   = 0.7
}
