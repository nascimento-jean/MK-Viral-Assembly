/*
    Per-module publishing rules and tool arguments.
*/

process {

    // Default: results are organised under one subfolder per virus
    // (${params.outdir}/<virus>/<category>). Per-sample processes carry meta.vdir;
    // per-virus aggregate processes carry a val(vdir) as the first tuple element.
    publishDir = [
        path: { "${params.outdir}/${meta.vdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: 'FASTQC_RAW' {
        ext.args   = '--quiet'
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/fastqc/raw" }, mode: params.publish_dir_mode ]
    }

    withName: 'FASTQC_TRIM' {
        ext.args   = '--quiet'
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/fastqc/trimmed" }, mode: params.publish_dir_mode ]
    }

    withName: 'FASTP' {
        // sensible defaults for viral clinical samples; override with -c
        ext.args   = '--cut_front --cut_tail --cut_mean_quality 20 --length_required 30 --detect_adapter_for_pe'
        publishDir = [
            path: { "${params.outdir}/${meta.vdir}/fastp/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'ALIGN:.*' {
        publishDir = [
            path: { "${params.outdir}/${meta.vdir}/alignment" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai}'
        ]
    }

    withName: 'IVAR_VARIANTS' {
        // raw iVar table is an intermediate; the published table comes from ANNOTATE_AA
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/variants" }, mode: params.publish_dir_mode, enabled: false ]
    }

    withName: 'ANNOTATE_AA' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/variants" }, mode: params.publish_dir_mode ]
    }

    withName: 'CAT_CONSENSUS' {
        publishDir = [ path: { "${params.outdir}/${vdir}/consensus" }, mode: params.publish_dir_mode ]
    }

    withName: 'IVAR_CONSENSUS' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/consensus" }, mode: params.publish_dir_mode ]
    }

    withName: 'CONSENSUS_QC' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/consensus_qc" }, mode: params.publish_dir_mode ]
    }

    withName: 'READ_STATS' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/read_stats" }, mode: params.publish_dir_mode ]
    }

    withName: 'DASHBOARD' {
        publishDir = [ path: { "${params.outdir}/${virus}" }, mode: params.publish_dir_mode ]
    }

    withName: 'MULTIQC' {
        publishDir = [ path: { "${params.outdir}/multiqc" }, mode: params.publish_dir_mode ]
    }

    withName: 'KRAKEN2' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/kraken2" }, mode: params.publish_dir_mode ]
    }

    withName: 'MIXED_SITES' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/mixed_sites" }, mode: params.publish_dir_mode ]
    }

    withName: 'TAXONOMY_SUMMARY' {
        publishDir = [ path: { "${params.outdir}/${vdir}/krona" }, mode: params.publish_dir_mode ]
    }

    withName: 'KRONA' {
        publishDir = [ path: { "${params.outdir}/${vdir}/krona" }, mode: params.publish_dir_mode ]
    }

    withName: 'KRONA_VALIDATION' {
        publishDir = [ path: { "${params.outdir}/${vdir}/run_validation" }, mode: params.publish_dir_mode ]
    }

    // per-sample Krona text files are intermediates → not published
    withName: 'KREPORT2KRONA' {
        publishDir = [ path: { "${params.outdir}/${meta.vdir}/krona" }, mode: params.publish_dir_mode, enabled: false ]
    }

    // Nextclade datasets are cached via storeDir (params.nextclade_datasets_dir) → do not publish to results
    withName: 'NEXTCLADE_DATASET_GET' {
        publishDir = [ path: { "${params.outdir}/nextclade" }, mode: params.publish_dir_mode, enabled: false ]
    }

    // raw per-segment Nextclade TSVs are intermediates → not published (summary is)
    withName: 'NEXTCLADE_RUN' {
        publishDir = [ path: { "${params.outdir}/nextclade" }, mode: params.publish_dir_mode, enabled: false ]
    }

    withName: 'NEXTCLADE_SUMMARY' {
        publishDir = [ path: { "${params.outdir}/${vdir}/nextclade" }, mode: params.publish_dir_mode ]
    }

    // RefSeq viral BLAST DB is persisted in params.blast_db_dir → do not copy into results
    withName: 'BLAST_DB_PREP' {
        publishDir = [ path: { "${params.outdir}/blast" }, mode: params.publish_dir_mode, enabled: false ]
    }

    // raw BLAST hits are an intermediate → not published (summary process is)
    withName: 'BLASTN_ID' {
        publishDir = [ path: { "${params.outdir}/${vdir}/blast" }, mode: params.publish_dir_mode, enabled: false ]
    }

    withName: 'BLAST_SUMMARY' {
        publishDir = [ path: { "${params.outdir}/${vdir}/blast" }, mode: params.publish_dir_mode ]
    }
}
